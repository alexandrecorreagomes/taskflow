# ==========================================
# .gitignore — TaskFlow (Vite + React + TS)
# ==========================================

# ── Dependências ──────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build / Output ────────────────────────
dist/
dist-ssr/
build/
out/
.output/

# ── Variáveis de Ambiente (SEGREDOS) ──────
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
# Manter apenas o exemplo sem segredos
!.env.example

# ── Cache ─────────────────────────────────
.cache/
.vite/
.eslintcache
.stylelintcache
*.tsbuildinfo

# ── Logs ──────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Editores e IDEs ───────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── Sistema Operacional ───────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Testes ────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────
*.local
*.orig
*.bak
